# إعدادات الخادم
PORT=3001
NODE_ENV=development

# قاعدة البيانات — PostgreSQL
DATABASE_URL="postgresql://msbg:msbg_dev_password@localhost:5432/ms_main_db?schema=public"

# المصادقة
# إلزامي — لا توجد قيمة احتياطية، الخادم يرفض الإقلاع بدونه
JWT_SECRET=change_this_to_a_secure_random_string_min_32_chars
JWT_EXPIRES_IN=30d

# حساب المسؤول الافتراضي (يُنشأ عبر npm run db:seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here
ADMIN_EMAIL=admin@example.com

# وضع الديمو — يقبل الرمز 000000 لأي رقم هاتف.
# يجب أن يبقى false في الإنتاج. الخادم يرفض الإقلاع لو كان true مع NODE_ENV=production.
DEMO_MODE=false

# خدمة الرسائل (Twilio - للإنتاج)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# إعدادات التطبيق
MAX_FILE_SIZE=5242880 # 5 ميجابايت بالبايت
MAX_IMAGES_PER_REPORT=5

# مصدر الترحيل من Mongo (يُستخدم مرة واحدة عبر npm run db:migrate-from-mongo)
MONGODB_URI=

# CORS — قائمة نطاقات مسموحة مفصولة بفواصل
CORS_ORIGINS=http://localhost:3000
